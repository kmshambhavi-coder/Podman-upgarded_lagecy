    "IntegrationSupportedActions": [
        {
            "Name": "Get Case",
            "Description": "Retrieve full details of a specific Abnormal Security case by its ID, including case status, severity, affected employees, and analysis summary.",
            "Id": 250,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "List Threats",
            "Description": "Retrieve a paginated list of threats from Abnormal Security. Use the Filter parameter to narrow results by time range (e.g. receivedTime gte 2025-01-01T00:00:00Z) or other supported fields.",
            "Id": 251,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Search Messages",
            "Description": "Search for email messages across your organization based on threat indicators such as time range, sender email, or subject. Returns a list of matching messages that can be passed to Remediate Messages for automated response.",
            "Id": 252,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Remediate Messages",
            "Description": "Take automated remediation action on email messages identified as threats. Returns an Activity Log ID that can be passed to Get Activity Status to verify the operation completed successfully.",
            "Id": 253,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Post Threat Action",
            "Description": "Take a remediation action on an Abnormal Security threat. Use 'remediate' to remediate detected messages, or 'unremediate' to reverse a remediation.",
            "Id": 254,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Post Case Action",
            "Description": "Update the status of an Abnormal Security case. Use 'action_required' to flag a case for attention, 'acknowledge' to mark it as reviewed, or 'close' to close the case.",
            "Id": 255,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Ping",
            "Description": "Test connectivity and authentication to the Abnormal Security API. Run this action after configuring the integration to verify the API URL and API key are valid before building playbooks.",
            "Id": 256,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Get Activity Status",
            "Description": "Check the status of a remediation operation using the Activity Log ID returned by Remediate Messages. Poll this action until the status reaches a terminal state (success, partial_success, or error).",
            "Id": 257,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "List Cases",
            "Description": "Retrieve a paginated list of cases from Abnormal Security. Use the Filter parameter to narrow results by time range or status (e.g. createdTime gte 2025-01-01T00:00:00Z).",
            "Id": 258,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        },
        {
            "Name": "Get Threat",
            "Description": "Retrieve full details of a specific Abnormal Security threat by its ID, including attack type, confidence score, disposition, affected messages, and available remediation actions.",
            "Id": 259,
            "CreationTimeUnixTimeInMs": 1780299186089,
            "ModificationTimeUnixTimeInMs": 1780299186089
        }
    ],
