a_required\":false,\"operation_blocked\":false,\"policy_disabled\":false,\"prevention_provisioning_enabled\":false,\"process_blocked\":false,\"quarantine_file\":false,\"quarantine_machine\":false,\"registry_operation_blocked\":false,\"response_action_already_applied\":false,\"response_action_failed\":false,\"response_action_triggered\":false,\"rooting\":false,\"sensor_only\":false,\"suspend_parent\":false,\"suspend_process\":false},\"pattern_id\":00000,\"platform\":\"Linux\",\"poly_id\":\"abcd==\",\"process_end_time\":\"1722324901\",\"process_id\":\"0000000\",\"process_start_time\":\"1722324901\",\"product\":\"epp\",\"scenario\":\"suspicious_activity\",\"seconds_to_resolved\":168,\"seconds_to_triaged\":0,\"severity\":70,\"severity_name\":\"High\",\"sha1\":\"0000000000000000000000000000000000000000\",\"sha256\":\"000000000000000\",\"show_in_ui\":true,\"source_products\":[\"FalconInsight\"],\"source_vendors\":[\"CrowdStrike\"],\"status\":\"new\",\"tactic\":\"FalconOverwatch\",\"tactic_id\":\"CSTA0006\",\"tags\":[\"true_positive\"],\"technique\":\"MaliciousActivity\",\"technique_id\":\"CST0002\",\"template_instance_id\":\"1359\",\"timestamp\":\"2024-07-30T07:35:02.101Z\",\"tree_id\":\"2965447926650\",\"tree_root\":\"312465436839417\",\"triggering_process_graph_id\":\"pid:2a1c5ef609ac479ba77f8ca5879c82fc:312465436839417\",\"type\":\"ldt\",\"updated_timestamp\":\"2024-07-30T08:27:57.39990427Z\",\"user_name\":\"root\"}]","DisplayResult":true}],"Parameters":[{"Type":"String","ActionId":0,"Id":0,"Mandatory":true,"DefaultValue":"","DisplayName":"Alert ID","Description":"Specify the ID of the alert that needs to be updated.","OptionalValues":[]},{"Type":"List","ActionId":0,"Id":0,"Mandatory":false,"DefaultValue":"Select One","DisplayName":"Status","Description":"Specify the status for the alert.","OptionalValues":["Select One","Closed","In Progress","New","Reopened"]},{"Type":"List","ActionId":0,"Id":0,"Mandatory":false,"DefaultValue":"Select One","DisplayName":"Verdict","Description":"Specify the verdict for the alert.","OptionalValues":["Select One","True Positive","False Positive"]},{"Type":"String","ActionId":0,"Id":0,"Mandatory":false,"DefaultValue":"","DisplayName":"Assign To","Description":"Specify the name of the analyst to whom the alert needs to be assigned. If \"Unassign\" is provided, action will remove assignment from the alert. Note: API will accept any value that is provided, even if the underlying user doesn’t exist.","OptionalValues":[]}],"AICategories":[],"AIDescription":"Updates the status, verdict, and assignment of a specific alert in CrowdStrike Falcon. This action allows analysts to programmatically manage the lifecycle of detections within the CrowdStrike console directly from Google SecOps.\n\n### Parameters Description\n\n| Parameter | Type | Mandatory | Description |\n| :--- | :--- | :--- | :--- |\n| **Alert ID** | String | Yes | The unique identifier (Composite ID) of the alert in CrowdStrike that needs to be updated. |\n| **Status** | DDL | No | The new status to assign to the alert. Options include: `Closed`, `In Progress`, `New`, `Reopened`. |\n| **Verdict** | DDL | No | The verdict to apply to the alert. Options include: `True Positive`, `False Positive`. |\n| **Assign To** | String | No | The name of the analyst to whom the alert should be assigned. Providing \"Unassign\" will remove the current assignment. |\n\n### Additional Notes\n- At least one of the optional parameters (**Status**, **Verdict**, or **Assign To**) must be provided for the action to execute.\n- The action performs a validation check to ensure the alert exists before attempting the update.\n\n### Flow Description\n1. **Parameter Extraction**: Retrieves the Alert ID and the desired update values (Status, Verdict, Assign To).\n2. **Validation**: Ensures that at least one update field is populated and validates the DDL selections.\n3. **Pre-update Verification**: Fetches the current details of the alert from CrowdStrike to confirm its existence.\n4. **Update Execution**: Sends a PATCH request to the CrowdStrike API to update the alert's metadata based on the provided parameters.\n5. **Result Retrieval**: Fetches the updated alert details to confirm the changes and returns the full alert object as JSON results.","AiShortDescription":null,"ParametersDescription":null,"EntityTypes":[],"OutcomeCategories":[]}